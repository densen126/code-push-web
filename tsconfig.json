{
    "compilerOptions": {
        "target": "ES2020",
        "lib": ["DOM", "ESNext"],
        "module": "CommonJS",
        "moduleResolution": "Node",
        "esModuleInterop": true,
        "allowSyntheticDefaultImports": true,
        "jsx": "react-jsx",
        "strict": true,
        "baseUrl": ".",
        "paths": {
            "@/*": ["src/*"]
        },
        "outDir": "dist",
        "resolveJsonModule": true,
        "skipLibCheck": true,
        "types": ["vitest", "node"]
    },
    "include": ["src", "test"]
}
